# Banco de dados
DATABASE_URL=postgresql://amparo_user:amparo_pass@localhost:5432/amparo_db

# JWT
SECRET_KEY=troque-esta-chave-por-uma-string-aleatoria-bem-longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Criptografia de campos sensíveis (EPDS).
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=coloque-uma-chave-fernet-gerada-aqui

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

ENVIRONMENT=development
